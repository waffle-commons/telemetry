{
    "name": "waffle-commons/telemetry",
    "description": "SDK-free enterprise telemetry for Waffle Commons: contract-first tracing no-ops, a Prometheus /waffle-metrics exporter, and stateless worker-metric collectors.",
    "version": "1.0.0-dev",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Waffle\\Commons\\Telemetry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WaffleTests\\Commons\\Telemetry\\": "tests/src/"
        }
    },
    "authors": [
        {
            "name": "Leslie Petrimaux",
            "email": "contact@waffle-commons.cloud"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.5",
        "waffle-commons/contracts": "self.version"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "carthage-software/mago": "^1.29",
        "vimeo/psalm": "^6.16",
        "php-mock/php-mock-phpunit": "^2.15",
        "cyclonedx/cyclonedx-php-composer": "^6.2",
        "igor-php/igor-php": "^0.7.0",
        "nyholm/psr7": "^1.8"
    },
    "scripts": {
        "formatter": "vendor/bin/mago fmt",
        "linter": "vendor/bin/mago lint",
        "analyzer": "vendor/bin/mago analyze",
        "guard": "vendor/bin/mago guard",
        "igor": "vendor/bin/igor-php .",
        "phpunit": "vendor/bin/phpunit --log-junit var/data/phpunit-coverage/junit.xml --coverage-html var/data/phpunit-coverage",
        "benchmark": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/phpbench run --report=default_report --output=waffle_html --retry-threshold=10"
        ],
        "mago": [
            "@formatter",
            "@linter",
            "@analyzer",
            "@guard"
        ],
        "tests": [
            "@phpunit"
        ],
        "scan": [
            "@mago",
            "@tests"
        ],
        "ci": [
            "@mago",
            "@tests",
            "composer audit",
            "vendor/bin/psalm --taint-analysis"
        ]
    },
    "config": {
        "allow-plugins": {
            "carthage-software/mago": true,
            "cyclonedx/cyclonedx-php-composer": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../contracts",
            "canonical": false,
            "options": {
                "symlink": false
            }
        }
    ]
}
